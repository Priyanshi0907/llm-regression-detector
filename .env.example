# ---- LLM Providers (multi-provider support) ----
# Configure any subset — the registry falls back to a deterministic mock
# for any provider without a key, so partial setups still work.
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here

# Default provider/model for the feature under test (override per-run with
# `--provider anthropic`, or run all three at once with `--providers openai,anthropic,gemini`)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# The judge is a FIXED provider regardless of which provider is under test,
# so cross-provider comparisons are all scored by the same judge.
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o-mini

# ---- Evaluation methodology ----
# Path to the configurable LLM-as-judge rubric (criteria + weights).
RUBRIC_PATH=golden_dataset/judge_rubric.yaml

# Optional second scoring dimension: embeddings-based semantic similarity.
# Off by default (extra API call per case). Falls back to a labeled
# token-overlap approximation when off or when no OpenAI key is set.
SEMANTIC_SIMILARITY_ENABLED=false
EMBEDDING_MODEL=text-embedding-3-small

# ---- Alerting (Slack / Discord / Email — configure any subset) ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=you@example.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_FROM=eval-bot@example.com
EMAIL_TO=team@example.com,oncall@example.com

# ---- Thresholds ----
WARNING_THRESHOLD_PCT=3.0
CRITICAL_THRESHOLD_PCT=8.0
DRIFT_WINDOW=7
DRIFT_THRESHOLD_PCT=5.0

# Rough blended $/1K tokens used only to show an illustrative cost-per-run
# figure in reports — not billing-accurate. Adjust to your provider's pricing.
COST_PER_1K_TOKENS=0.015

# ---- Runtime ----
# Set to "true" to run without any API key using a deterministic mock LLM.
# Great for demos, CI smoke tests, and local development.
MOCK_MODE=true

# ---- Report base URL (used in alert links) ----
REPORT_BASE_URL=https://your-domain.com/reports
